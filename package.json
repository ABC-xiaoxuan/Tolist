{
  "name": "minimal-todo-electron",
  "version": "0.1.0",
  "description": "MinimalTodo for Windows built with Electron, React and SQLite",
  "main": "dist-electron/main/main.js",
  "author": "OpenAI Codex",
  "license": "MIT",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:renderer\" \"npm:dev:electron\"",
    "dev:renderer": "vite",
    "dev:electron": "wait-on tcp:5173 && tsc -p tsconfig.electron.json && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .",
    "build": "vite build && tsc -p tsconfig.electron.json",
    "start": "electron .",
    "dist": "npm run build && electron-builder --win",
    "rebuild:native": "electron-builder install-app-deps"
  },
  "build": {
    "appId": "com.codex.minimaltodo",
    "productName": "极简待办",
    "directories": {
      "output": "release"
    },
    "files": [
      "build/**/*",
      "dist/**/*",
      "dist-electron/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "asar": true,
    "win": {
      "icon": "build/icon.ico",
      "target": "nsis"
    },
    "nsis": {
      "guid": "e9182856-48c1-55b8-9a40-d13f65c66f2a",
      "oneClick": true,
      "perMachine": false,
      "deleteAppDataOnUninstall": false,
      "uninstallDisplayName": "极简待办 ${version}"
    }
  },
  "dependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "better-sqlite3": "^11.10.0",
    "electron-log": "^5.4.0",
    "lucide-react": "^0.511.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^24.0.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^35.5.1",
    "electron-builder": "^26.0.12",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "wait-on": "^8.0.3"
  }
}
